# ============================================
# AssuredReferral AutoPoster — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# For GitHub Actions, add these as repository secrets.

# ============================================
# SHARED SERVICES (used by all products)
# ============================================

# --- Azure OpenAI (REQUIRED) ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1-mini

# --- Image Generation ---
IMAGE_PROVIDER=stock
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
PEXELS_API_KEY=your-pexels-api-key

# --- Research Layer (OPTIONAL) ---
TAVILY_API_KEY=tvly-your-tavily-api-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789


# ============================================
# PRODUCT: ASSUREDREFERRAL
# ============================================
# Naming convention: {PLATFORM}_{FIELD}_{PRODUCT}

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN_ASSUREDREFERRAL=AQVhj...your-linkedin-access-token
LINKEDIN_PERSON_URN_ASSUREDREFERRAL=urn:li:person:Ab1CdE2fGh

# --- YouTube ---
YOUTUBE_CLIENT_ID_ASSUREDREFERRAL=123456789-abcdefg.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET_ASSUREDREFERRAL=GOCSPX-your-client-secret
YOUTUBE_REFRESH_TOKEN_ASSUREDREFERRAL=1//0abc...your-refresh-token
YOUTUBE_CHANNEL_ID_ASSUREDREFERRAL=UCxxxxxxxxxxxxxxxx

# --- Instagram ---
INSTAGRAM_ACCESS_TOKEN_ASSUREDREFERRAL=EAABx...your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID_ASSUREDREFERRAL=17841400000000000
FACEBOOK_PAGE_ID_ASSUREDREFERRAL=100000000000000


# ============================================
# PRODUCT: EXAMPLE_PRODUCT_2 (copy for new products)
# ============================================

# --- LinkedIn ---
# LINKEDIN_ACCESS_TOKEN_PRODUCT2=your-token
# LINKEDIN_PERSON_URN_PRODUCT2=urn:li:person:xxxxx

# --- YouTube ---
# YOUTUBE_CLIENT_ID_PRODUCT2=your-client-id
# YOUTUBE_CLIENT_SECRET_PRODUCT2=your-client-secret
# YOUTUBE_REFRESH_TOKEN_PRODUCT2=your-refresh-token
# YOUTUBE_CHANNEL_ID_PRODUCT2=your-channel-id

# --- Instagram ---
# INSTAGRAM_ACCESS_TOKEN_PRODUCT2=your-token
# INSTAGRAM_BUSINESS_ACCOUNT_ID_PRODUCT2=your-account-id
# FACEBOOK_PAGE_ID_PRODUCT2=your-page-id


# ============================================
# LEGACY (backward compatibility)
# ============================================
# These work if product-specific secrets are not set

LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:xxxxx
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=your-channel-id
