# ============================================
# AssuredReferral AutoPoster — Configuration
# ============================================
# Copy this file to .env and fill in your values
# OR add these as GitHub Secrets (recommended for GitHub Actions)

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names (create these in Azure OpenAI Studio)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o          # Your GPT-4o deployment name
AZURE_OPENAI_DALLE_DEPLOYMENT=dall-e-3       # Your DALL-E 3 deployment name

# --- Image Generation ---
# "azure" uses DALL-E 3 via Azure OpenAI (same key)
# "stability" uses Stability AI (separate key)
# "gradient" uses local gradient generation (free, no API needed)
IMAGE_PROVIDER=azure
# STABILITY_API_KEY=your-stability-key-here  # Only if IMAGE_PROVIDER=stability

# --- LinkedIn (3-legged OAuth) ---
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID
LINKEDIN_ORG_ID=your-company-page-id

# --- YouTube ---
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=your-channel-id

# --- Instagram (placeholder — fill when ready) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# --- General ---
BRAND_NAME=AssuredReferral
BRAND_URL=https://assuredreferral.com
POSTING_TIME=10:00  # IST, 24h format
CONTENT_NICHE=business_startup
TONE=inspirational_bold
