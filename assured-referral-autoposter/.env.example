# ============================================
# AssuredReferral AutoPoster — Configuration
# ============================================
# Copy this file to .env and fill in your values
# OR add these as GitHub Secrets (recommended for GitHub Actions)

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names (create these in Azure OpenAI Studio)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o                # Your GPT-4o deployment name
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1-mini     # Your image model deployment name

# --- Image Generation ---
# "stock" uses Unsplash/Pexels for aesthetic photos (recommended)
# "azure" uses DALL-E 3 via Azure OpenAI
# "stability" uses Stability AI
# "gradient" uses local gradient generation (free, no API needed)
IMAGE_PROVIDER=stock

# Stock Photo APIs (free tiers available)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key    # unsplash.com/developers - 50 req/hr free
PEXELS_API_KEY=your-pexels-api-key              # pexels.com/api - 200 req/month free

# AI Image Generation (optional, if IMAGE_PROVIDER=azure or stability)
# STABILITY_API_KEY=your-stability-key-here

# --- LinkedIn (3-legged OAuth) ---
# Run: .venv/bin/python get_linkedin_token.py  to get a fresh token (expires every ~60 days)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# --- YouTube ---
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=your-channel-id

# --- Instagram (placeholder — fill when ready) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# --- Research Layer (for trending content) ---
TAVILY_API_KEY=your-tavily-api-key        # tavily.com - 1000 req/month free
REDDIT_CLIENT_ID=your-reddit-client-id     # reddit.com/prefs/apps - create a "script" app
REDDIT_CLIENT_SECRET=your-reddit-secret

# --- General ---
BRAND_NAME=AssuredReferral
BRAND_URL=https://assuredreferral.com
POSTING_TIME=10:00  # IST, 24h format
CONTENT_NICHE=business_startup
TONE=inspirational_bold
