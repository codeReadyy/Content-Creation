# connect-helper settings — copy to connect-helper/.env and fill in.
# (This file is decoupled from the engine; it only WRITES the engine's .env + GitHub.)

# --- Google / YouTube OAuth client ---------------------------------------------
# Reuse your existing NinniTales OAuth client. If these are blank, the helper falls
# back to YOUTUBE_CLIENT_ID_NINNITALES / _SECRET_NINNITALES in ninnitales-shorts/.env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Instagram (Instagram-login path) ------------------------------------------
# The INSTAGRAM App ID/Secret (NOT the Meta app id) — from your Meta app →
# Instagram product → "API setup with Instagram login" → Instagram app ID / secret.
# See README for the full one-time setup.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# --- Optional overrides ---------------------------------------------------------
# CONNECT_PORT=8765
# CONNECT_HTTPS=1            # 1 = serve self-signed HTTPS (required for Instagram)
# CONNECT_IG_INSIGHTS=1      # 0 = connect Instagram WITHOUT the insights scope (no view metrics)
# TARGET_ENV=../ninnitales-shorts/.env
# TARGET_ACCOUNTS_YML=../ninnitales-shorts/config/accounts.yml
# DEFAULT_PRODUCT=ninnitales
# DEFAULT_NICHE=toddler_sleep
